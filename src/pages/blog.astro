---
import Layout from '../layouts/Layout.astro';

// Fetch all blog posts from markdown files
const allPosts = import.meta.glob('./blog/*.md', { eager: true });

// Extract frontmatter and slug, then sort by date (newest first)
const posts = Object.entries(allPosts)
  .map(([path, post]: [string, any]) => ({
    title: post.frontmatter.title,
    slug: path.split('/').pop()?.replace('.md', ''),
    date: post.frontmatter.date,
    description: post.frontmatter.description,
  }))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<Layout title="Blog - Joe Cardoso">
  <h1>$ ls blog/*</h1>
  
  <div class="blog-list">
    {posts.map((post) => (
      <article class="post-preview">
        <div class="post-meta">
          <time>{post.date}</time>
        </div>
        <h2>
          <a href={`/blog/${post.slug}`}>{post.title}</a>
        </h2>
        <p>{post.description}</p>
        <a href={`/blog/${post.slug}`} class="read-more">read more →</a>
      </article>
    ))}
  </div>

  <div class="medium-link">
    <p>
      I also write on <a href="https://medium.com/@joecardoso1312" target="_blank">Medium</a> 
      for broader reach. This blog serves as the canonical source for my writing.
    </p>
  </div>
</Layout>

<style>
  h1 {
    color: var(--accent);
    margin-bottom: 3rem;
  }

  .blog-list {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .post-preview {
    border-bottom: 1px solid var(--border);
    padding-bottom: 2rem;
  }

  .post-preview:last-child {
    border-bottom: none;
  }

  .post-meta {
    margin-bottom: 0.5rem;
  }

  .post-meta time {
    color: var(--text-dim);
    font-size: 0.9rem;
  }

  .post-preview h2 {
    font-size: 1.6rem;
    margin-bottom: 1rem;
    margin-top: 0;
  }

  .post-preview h2 a {
    color: var(--text);
    text-decoration: none;
  }

  .post-preview h2 a:hover {
    color: var(--accent);
  }

  .post-preview p {
    color: var(--text-dim);
    margin-bottom: 1rem;
  }

  .read-more {
    font-size: 0.95rem;
    color: var(--accent);
  }

  .read-more:hover {
    text-decoration: underline;
  }

  .medium-link {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    color: var(--text-dim);
  }
</style>
