---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    title: 'vispyr',
    href: 'https://vispyr.com',
    external: true,
    description: 'Self-hosted, open-source observability tool combining continuous profiling with traditional telemetry data. Features CLI-driven AWS deployment, pre-configured telemetry data storage, and a custom Grafana dashboard.',
    tech: ['otel', 'grafana', 'docker', 'aws', 'bash'],
  },
  {
    title: 'brush up python',
    href: '/brush-up-py',
    external: false,
    description: 'A Socratic Python tutor powered by AI. It leverages my Zettelkasten notes and is tuned to do interactive, conversational teaching.',
    tech: ['svelte', 'claude api', 'fastapi', 'tf-idf'],
  },
  {
    title: 'brush up ruby',
    href: '/brush-up-rb',
    external: false,
    description: 'A Socratic Ruby tutor powered by AI. It leverages my Zettelkasten notes and is tuned to do interactive, conversational teaching.',
    tech: ['svelte', 'claude api', 'fastapi', 'tf-idf'],
  },
  {
    title: 'brush up javascript',
    href: '/brush-up-js',
    external: false,
    description: 'A Socratic JavaScript tutor powered by AI. It leverages my Zettelkasten notes and is tuned to do interactive, conversational teaching.',
    tech: ['svelte', 'claude api', 'fastapi', 'tf-idf'],
  },
  {
    title: 'firefox contributions',
    href: 'https://bugzilla.mozilla.org/user_profile?user_id=780254',
    external: true,
    description: 'Active contributor to improving accessibility features, refactoring CSS on a large scale, removing security sensitive feature flag, fixing PDF rendering, etc.',
    tech: ['c++', 'javascript', 'accessibility', 'react', 'CSS'],
  },
];

const PAGE_SIZE = 2;
const pages: typeof projects[] = [];
for (let i = 0; i < projects.length; i += PAGE_SIZE) {
  pages.push(projects.slice(i, i + PAGE_SIZE));
}
// Ensure the last page is full by pulling from earlier items
if (pages.length > 1 && pages[pages.length - 1].length < PAGE_SIZE) {
  const lastPageStart = projects.length - PAGE_SIZE;
  pages[pages.length - 1] = projects.slice(lastPageStart);
}

const allPosts = import.meta.glob('./blog/*.md', { eager: true });
const recentPosts = Object.entries(allPosts)
  .map(([path, post]: [string, any]) => ({
    title: post.frontmatter.title,
    slug: path.split('/').pop()?.replace('.md', ''),
    date: post.frontmatter.date,
  }))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 4);
---

<Layout title="Joe Cardoso - Software Engineer">
  <div class="hero">
    <pre class="ascii-art">
┌─────────────────┐
│ > hello_world   │
│ > _             │
└─────────────────┘
   </pre>
    <h1>joe cardoso</h1>
    <p class="tagline">full-stack engineer • open source contributor • toronto, canada</p>
  </div>

  <section class="intro">
    <p>
    Welcome to my corner of the web! Here you'll see my documented journey tinkering with cloud infrastructure, all kinds of APIs, and leveraging AI agents to build some really cool stuff. Feel free to skim through or stick around.
    </p>
  </section>

  <section class="projects">
    <h2>$ ls projects/</h2>
    <div class="carousel">
      <div class="carousel-track" data-page-count={pages.length}>
        {pages.map((group) => (
          <div class="carousel-page">
            {group.map((project) => (
              <article class="project">
                <h3>
                  <a href={project.href} {...(project.external ? { target: '_blank' } : {})}>
                    {project.title}
                  </a>
                </h3>
                <p>{project.description}</p>
                <div class="tech-stack">
                  {project.tech.map((t) => <span>{t}</span>)}
                </div>
              </article>
            ))}
          </div>
        ))}
      </div>
    </div>
    {pages.length > 1 && (
      <div class="carousel-nav">
        <button class="carousel-arrow carousel-prev" aria-label="Previous projects" disabled>&larr;</button>
        <button class="carousel-arrow carousel-next" aria-label="Next projects">&rarr;</button>
      </div>
    )}
  </section>

  <section class="blog-preview">
    <h2>$ cat recent_posts.txt</h2>
    <ul class="recent-posts">
      {recentPosts.map((post) => (
        <li>
          <a href={`/blog/${post.slug}`}>{post.title}</a>
          <time>{post.date}</time>
        </li>
      ))}
    </ul>
    <a href="/blog" class="view-all">view all posts →</a>
  </section>

  <section class="contact">
    <h2>$ echo $CONTACT</h2>
    <div class="links">
      <a href="https://github.com/JoeCardoso13" target="_blank">github</a>
      <a href="https://linkedin.com/in/joe-cardoso-eng" target="_blank">linkedin</a>
      <a href="mailto:jow13_122@yahoo.com">email</a>
      <a href="https://drive.google.com/file/d/1kXCv-RyYcL7W-Ic2bCBPYUAcQBW2B7jV/view" target="_blank">resume</a>
    </div>
  </section>
</Layout>

<style>
  .hero {
    margin-bottom: 4rem;
  }

  .ascii-art {
    color: var(--accent);
    font-size: 4rem;
    line-height: 1.2;
    margin-bottom: 1rem;
    background: none;
    padding: 0;
  }

  .hero h1 {
    font-size: 3rem;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .tagline {
    color: var(--text-dim);
    font-size: 1rem;
  }

  .intro {
    margin-bottom: 4rem;
    font-size: 1.1rem;
    line-height: 1.8;
  }

  .carousel {
    overflow: hidden;
  }

  .carousel-track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 100%;
    transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .carousel-page {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .carousel-nav {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .carousel-arrow {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-dim);
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 4px;
    cursor: pointer;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s, color 0.2s;
  }

  .carousel-arrow:hover:not(:disabled) {
    border-color: var(--accent);
    color: var(--accent);
  }

  .carousel-arrow:disabled {
    opacity: 0.2;
    cursor: default;
  }

  .project {
    border: 1px solid var(--border);
    padding: 1.5rem;
    border-radius: 5px;
    transition: border-color 0.2s;
  }

  .project:hover {
    border-color: var(--accent);
  }

  .project h3 {
    font-size: 1.2rem;
    margin-bottom: 0.8rem;
  }

  .project h3 a {
    color: var(--text);
  }

  .project h3 a:hover {
    color: var(--accent);
  }

  .project p {
    color: var(--text-dim);
    margin-bottom: 1rem;
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tech-stack span {
    background: #1a1a1a;
    color: var(--accent);
    padding: 0.3rem 0.8rem;
    border-radius: 3px;
    font-size: 0.85rem;
  }

  .recent-posts {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .recent-posts li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.8rem 0;
    border-bottom: 1px solid var(--border);
  }

  .recent-posts li:last-child {
    border-bottom: none;
  }

  .recent-posts a {
    color: var(--text);
  }

  .recent-posts a:hover {
    color: var(--accent);
  }

  .recent-posts time {
    color: var(--text-dim);
    font-size: 0.85rem;
  }

  .view-all {
    display: inline-block;
    margin-top: 1rem;
    font-size: 0.95rem;
  }

  :global(html) {
    overflow-x: hidden;
  }

  @media (max-width: 640px) {
    .ascii-art {
      display: none;
    }

    .hero h1 {
      font-size: 2rem;
    }

    .tagline {
      font-size: 0.9rem;
    }

    .project {
      padding: 1.75rem;
    }

    .project h3 {
      font-size: 1.5rem;
      text-align: center;
      margin-bottom: 1.2rem;
    }

    .project p {
      font-size: 1.05rem;
      text-align: left;
    }

    .tech-stack {
      justify-content: center;
    }

    .recent-posts li {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.3rem;
      padding: 1rem 0;
    }

    .intro {
      font-size: 1rem;
    }

    section {
      margin-bottom: 3rem;
    }
  }
</style>

<script>
  const track = document.querySelector<HTMLElement>('.carousel-track');
  const prevBtn = document.querySelector<HTMLButtonElement>('.carousel-prev');
  const nextBtn = document.querySelector<HTMLButtonElement>('.carousel-next');

  if (track && prevBtn && nextBtn) {
    const pageCount = Number(track.dataset.pageCount) || 1;
    let current = 0;

    function update() {
      track!.style.transform = `translateX(-${current * 100}%)`;
      prevBtn!.disabled = current === 0;
      nextBtn!.disabled = current === pageCount - 1;
    }

    prevBtn.addEventListener('click', () => {
      if (current > 0) { current--; update(); }
    });

    nextBtn.addEventListener('click', () => {
      if (current < pageCount - 1) { current++; update(); }
    });
  }
</script>
